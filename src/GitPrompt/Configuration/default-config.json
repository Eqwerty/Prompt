{
  // Cache configuration
  "cache": {

    // How long to cache the git status segment, in seconds.
    // Set to 0 to disable git status caching.
    "gitStatusTtl": 5,

    // How long to cache the repository location, in seconds.
    // Set to 0 to disable repository location caching.
    "repositoryTtl": 60

  }
}
